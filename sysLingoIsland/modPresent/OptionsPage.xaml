<UserControl x:Class="LingoIsland.Present.OptionsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Focusable="True" FontSize="14">
  <!-- 區塊序依使用頻率與關聯（Issue #40）：①AI 辨識翻譯（金鑰＋模型）②朗讀語音（含測試發音）…
       喚起快捷鍵設定已於 #133 搬至「螢幕擷取」分頁（與手動擷取同區），本頁不再呈現。 -->
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="18,14,18,14">

      <Border Style="{StaticResource Card}" Padding="12" Margin="0,0,0,10">
        <StackPanel>
          <TextBlock Text="AI 辨識與翻譯（OpenAI）" FontWeight="SemiBold" Foreground="{StaticResource PinkText}"/>
          <TextBlock Text="API 金鑰（OPENAI_API_KEY）" FontSize="12.5" Foreground="{StaticResource PinkSub}" Margin="0,6,0,0"/>
          <TextBlock x:Name="KeyStatus" Margin="0,2,0,4" Foreground="{StaticResource PinkSub}"/>
          <PasswordBox x:Name="KeyBox" Padding="6"/>
          <TextBlock Text="貼上以更新；留空則保持不變。存於你的使用者環境變數，絕不寫入程式或設定檔。"
                     FontSize="12" Foreground="#9A6A82" TextWrapping="Wrap" Margin="0,3,0,0"/>
          <StackPanel Orientation="Horizontal" Margin="0,10,0,0" VerticalAlignment="Center">
            <TextBlock Text="查詢模型（視覺）" FontSize="12.5" Foreground="{StaticResource PinkSub}"
                       VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox x:Name="QueryModelBox" Padding="6,4" MinWidth="200"/>
          </StackPanel>
        </StackPanel>
      </Border>

      <Border Style="{StaticResource Card}" Padding="12" Margin="0,0,0,10">
        <StackPanel>
          <TextBlock Text="朗讀語音（Windows 內建）" FontWeight="SemiBold" Foreground="{StaticResource PinkText}"/>
          <StackPanel Orientation="Horizontal" Margin="0,4,0,4">
            <ComboBox x:Name="VoiceBox" MinWidth="260"/>
            <Button x:Name="TestBtn" Content="測試發音" Style="{StaticResource GhostButton}" Margin="10,0,0,0"/>
          </StackPanel>
          <TextBlock Text="使用系統已安裝的 Windows 語音；離線運作、無用量限制。"
                     FontSize="12" Foreground="#9A6A82" TextWrapping="Wrap"/>
        </StackPanel>
      </Border>

      <Border Style="{StaticResource Card}" Padding="12" Margin="0,0,0,10">
        <StackPanel>
          <TextBlock Text="發音練習" FontWeight="SemiBold" Foreground="{StaticResource PinkText}"/>
          <TextBlock Text="在「我的筆記」中，按住卡片上的麥克風錄音、放開即評分；當你的最佳分數達到及格門檻時，分數框會轉為綠色。"
                     FontSize="12" Foreground="{StaticResource PinkSub}" Margin="0,6,0,0" TextWrapping="Wrap"/>
          <StackPanel Orientation="Horizontal" Margin="0,8,0,0" VerticalAlignment="Center">
            <TextBlock Text="及格門檻" FontSize="12.5" Foreground="{StaticResource PinkSub}"
                       VerticalAlignment="Center" Margin="0,0,10,0"/>
            <Slider x:Name="PronThresholdSlider" Minimum="0" Maximum="100" Width="200"
                    IsSnapToTickEnabled="False" VerticalAlignment="Center"/>
            <TextBox x:Name="PronThresholdBox" Width="46" Margin="10,0,4,0" Padding="4,2"
                     TextAlignment="Center" VerticalAlignment="Center"/>
            <TextBlock Text="/ 100" FontSize="12" Foreground="{StaticResource PinkSub}" VerticalAlignment="Center"/>
          </StackPanel>
          <StackPanel Orientation="Horizontal" Margin="0,10,0,0" VerticalAlignment="Center">
            <TextBlock Text="評分模型（音訊）" FontSize="12.5" Foreground="{StaticResource PinkSub}"
                       VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox x:Name="PronModelBox" Padding="6,4" MinWidth="200"/>
          </StackPanel>
          <TextBlock Text="使用你的 OpenAI 金鑰與具音訊能力的模型；錄音會送至 OpenAI 評分、不予保存。"
                     FontSize="12" Foreground="#9A6A82" TextWrapping="Wrap" Margin="0,3,0,0"/>
        </StackPanel>
      </Border>

      <Border Style="{StaticResource Card}" Padding="12" Margin="0,0,0,10">
        <StackPanel>
          <TextBlock Text="筆記／歷史條目" FontWeight="SemiBold" Foreground="{StaticResource PinkText}"/>
          <TextBlock Text="條目文字在「我的筆記」與「歷史」清單中的顯示方式。"
                     FontSize="12" Foreground="{StaticResource PinkSub}" Margin="0,6,0,0" TextWrapping="Wrap"/>
          <StackPanel Orientation="Horizontal" Margin="0,8,0,0" VerticalAlignment="Center">
            <TextBlock Text="字級" FontSize="12.5" Foreground="{StaticResource PinkSub}"
                       VerticalAlignment="Center" Margin="0,0,10,0"/>
            <Slider x:Name="EntryFontSlider" Minimum="12" Maximum="32" Width="200"
                    IsSnapToTickEnabled="True" TickFrequency="1" VerticalAlignment="Center"/>
            <TextBox x:Name="EntryFontBox" Width="46" Margin="10,0,4,0" Padding="4,2"
                     TextAlignment="Center" VerticalAlignment="Center"/>
            <TextBlock Text="pt" FontSize="12" Foreground="{StaticResource PinkSub}" VerticalAlignment="Center"/>
          </StackPanel>
          <CheckBox x:Name="EntryBoldChk" Content="粗體" Margin="0,10,0,0" Foreground="{StaticResource PinkText}"/>
          <CheckBox x:Name="EntryWrapChk" Content="長文字換行（否則單行以 … 截斷）"
                    Margin="0,6,0,0" Foreground="{StaticResource PinkText}"/>
          <StackPanel Orientation="Horizontal" Margin="0,10,0,0" VerticalAlignment="Center">
            <TextBlock Text="背景不透明度" FontSize="12.5" Foreground="{StaticResource PinkSub}"
                       VerticalAlignment="Center" Margin="0,0,10,0"/>
            <Slider x:Name="EntryOpacitySlider" Minimum="0" Maximum="100" Width="200"
                    IsSnapToTickEnabled="True" TickFrequency="1" VerticalAlignment="Center"/>
            <TextBox x:Name="EntryOpacityBox" Width="46" Margin="10,0,4,0" Padding="4,2"
                     TextAlignment="Center" VerticalAlignment="Center"/>
            <TextBlock Text="%" FontSize="12" Foreground="{StaticResource PinkSub}" VerticalAlignment="Center"/>
          </StackPanel>
          <TextBlock Text="卡片背景不透明度，對「我的筆記」與「歷史」條目一致套用。0% ＝ 完全透明（透出吉祥物）；100% ＝ 不透明。"
                     FontSize="12" Foreground="{StaticResource PinkSub}" Margin="0,4,0,0" TextWrapping="Wrap"/>
        </StackPanel>
      </Border>

      <Border Style="{StaticResource Card}" Padding="12" Margin="0,0,0,10">
        <StackPanel>
          <TextBlock Text="影片字幕" FontWeight="SemiBold" Foreground="{StaticResource PinkText}"/>
          <TextBlock Text="影片播放器下方目前字幕行（可點字的大字行）的字型。"
                     FontSize="12" Foreground="{StaticResource PinkSub}" Margin="0,6,0,0" TextWrapping="Wrap"/>
          <StackPanel Orientation="Horizontal" Margin="0,8,0,0" VerticalAlignment="Center">
            <TextBlock Text="字級" FontSize="12.5" Foreground="{StaticResource PinkSub}"
                       VerticalAlignment="Center" Margin="0,0,10,0"/>
            <Slider x:Name="SubtitleFontSlider" Minimum="12" Maximum="48" Width="200"
                    IsSnapToTickEnabled="True" TickFrequency="1" VerticalAlignment="Center"/>
            <TextBox x:Name="SubtitleFontBox" Width="46" Margin="10,0,4,0" Padding="4,2"
                     TextAlignment="Center" VerticalAlignment="Center"/>
            <TextBlock Text="pt" FontSize="12" Foreground="{StaticResource PinkSub}" VerticalAlignment="Center"/>
          </StackPanel>
          <CheckBox x:Name="SubtitleBoldChk" Content="粗體" Margin="0,10,0,0" Foreground="{StaticResource PinkText}"/>
        </StackPanel>
      </Border>

      <Border Style="{StaticResource Card}" Padding="12" Margin="0,0,0,10">
        <StackPanel>
          <TextBlock Text="影片清單縮圖" FontWeight="SemiBold" Foreground="{StaticResource PinkText}"/>
          <TextBlock Text="影片清單中縮圖的大小。越大越好預覽；列高與寬度一同縮放（16:9）。"
                     FontSize="12" Foreground="{StaticResource PinkSub}" Margin="0,6,0,0" TextWrapping="Wrap"/>
          <StackPanel Orientation="Horizontal" Margin="0,8,0,0" VerticalAlignment="Center">
            <TextBlock Text="縮圖高度" FontSize="12.5" Foreground="{StaticResource PinkSub}"
                       VerticalAlignment="Center" Margin="0,0,10,0"/>
            <Slider x:Name="ThumbSizeSlider" Minimum="28" Maximum="120" Width="200"
                    IsSnapToTickEnabled="True" TickFrequency="2" VerticalAlignment="Center"/>
            <TextBox x:Name="ThumbSizeBox" Width="46" Margin="10,0,4,0" Padding="4,2"
                     TextAlignment="Center" VerticalAlignment="Center"/>
            <TextBlock Text="px" FontSize="12" Foreground="{StaticResource PinkSub}" VerticalAlignment="Center"/>
          </StackPanel>
        </StackPanel>
      </Border>

      <Border Style="{StaticResource Card}" Padding="12" Margin="0,0,0,10">
        <StackPanel>
          <TextBlock Text="字典結果" FontWeight="SemiBold" Foreground="{StaticResource PinkText}"/>
          <TextBlock Text="字典結果的基準字級。音標與中文行會隨之縮放。"
                     FontSize="12" Foreground="{StaticResource PinkSub}" Margin="0,10,0,0" TextWrapping="Wrap"/>
          <StackPanel Orientation="Horizontal" Margin="0,8,0,0" VerticalAlignment="Center">
            <TextBlock Text="字級" FontSize="12.5" Foreground="{StaticResource PinkSub}"
                       VerticalAlignment="Center" Margin="0,0,10,0"/>
            <Slider x:Name="ResultFontSlider" Minimum="16" Maximum="40" Width="200"
                    IsSnapToTickEnabled="True" TickFrequency="1" VerticalAlignment="Center"/>
            <TextBox x:Name="ResultFontBox" Width="46" Margin="10,0,4,0" Padding="4,2"
                     TextAlignment="Center" VerticalAlignment="Center"/>
            <TextBlock Text="pt" FontSize="12" Foreground="{StaticResource PinkSub}" VerticalAlignment="Center"/>
          </StackPanel>
        </StackPanel>
      </Border>

      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,0,0">
        <Button x:Name="SaveBtn" Content="儲存" Style="{StaticResource PinkButton}"/>
      </StackPanel>

    </StackPanel>
  </ScrollViewer>
</UserControl>
