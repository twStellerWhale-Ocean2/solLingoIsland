<UserControl x:Class="LingoIsland.Present.NotesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <UserControl.Resources>
    <!-- 卡片行尾圓形圖示鈕（spec#10）：播音／麥克風同款圓鈕，明示可按；顏色由實體 Background/BorderBrush/Foreground 指定。 -->
    <Style x:Key="RoundIcon" TargetType="Button">
      <Setter Property="Width" Value="27"/>
      <Setter Property="Height" Value="27"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="bg" CornerRadius="13.5"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="bg" Property="Opacity" Value="0.82"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </UserControl.Resources>
  <Grid>
    <!-- 左側欄寬可拖拉調整（Issue #58）：GridSplitter 於中間 Auto 欄 -->
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="212" MinWidth="150"/>
      <ColumnDefinition Width="Auto"/>
      <ColumnDefinition Width="*" MinWidth="240"/>
    </Grid.ColumnDefinitions>

    <!-- 左：頂部工具列（僅建立資料夾）＋標準多層資料夾樹（右鍵選單／F2 原地更名，Issue #38） -->
    <Grid Grid.Column="0" Margin="10,8,4,10">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>
      <Button x:Name="NewFolderBtn" Grid.Row="0" Content="＋ 新增資料夾" Style="{StaticResource GhostButton}"
              HorizontalAlignment="Left" Padding="10,4" Margin="0,0,0,6"/>
      <Border Grid.Row="1" Style="{StaticResource Card}">
        <!-- USR：長資料夾名自動分行——停用水平捲軸使列寬受欄寬約束（配合 MakeItem 列拉伸＋名稱 TextWrapping） -->
        <TreeView x:Name="FolderTree" BorderThickness="0" Background="Transparent" AllowDrop="True" Margin="2"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>
      </Border>
    </Grid>

    <GridSplitter Grid.Column="1" Style="{StaticResource ColSplitter}"/>

    <!-- 右：選取夾之條目（右欄頂[清除全部]，比照歷史分頁；Issue #42） -->
    <Grid Grid.Column="2" Margin="4,8,10,10">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>
      <!-- 條目工具列（#126：字母／日期／自訂 三顆 toggle 排序鈕＋Clear Practice；WrapPanel 換行——窄欄全可視可點） -->
      <WrapPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,6">
        <!-- #126：四排序鈕收為三顆 toggle——內容（含方向字圖 ▲/▼）、粗體、深色由程式依 f.Sort 更新（作用中非顏色線索＝方向字圖存在） -->
        <Button x:Name="AlphaSortBtn" Content="字母" Style="{StaticResource GhostButton}" Margin="0,0,6,4"
                ToolTip="依文字排序（A→Z／Z→A）。點擊可切換方向——僅改變檢視；你的自訂拖曳順序會保留。"/>
        <Button x:Name="TimeSortBtn" Content="日期" Style="{StaticResource GhostButton}" Margin="0,0,6,4"
                ToolTip="依加入日期排序（新→舊／舊→新）。點擊可切換方向——僅改變檢視；你的自訂順序會保留。"/>
        <Button x:Name="ManualSortBtn" Content="自訂" Style="{StaticResource GhostButton}" Margin="0,0,6,4"
                ToolTip="自訂順序——你自己的拖曳順序（正向／反向）。拖曳卡片即切換為此模式。"/>
        <Button x:Name="ClearPracticeBtn" Content="清除練習紀錄"
                ToolTip="重設此資料夾內所有發音練習的成績框（保留筆記）"
                Foreground="#8A2B2B" Style="{StaticResource GhostButton}" Margin="0,0,0,4"/>
      </WrapPanel>
      <Grid Grid.Row="1">
        <ScrollViewer x:Name="EntryScroll" VerticalScrollBarVisibility="Auto" Padding="8,0,4,0">
          <StackPanel x:Name="EntryPanel"/>
        </ScrollViewer>
        <TextBlock x:Name="EmptyHint" Text="此資料夾尚無筆記。在查詢結果或歷史條目上使用「加入我的筆記」即可儲存；在左側資料夾按右鍵可管理，拖曳即可移動。"
                   Foreground="#9A6A82" FontSize="13" TextWrapping="Wrap" MaxWidth="320"
                   TextAlignment="Center" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
      </Grid>
    </Grid>
  </Grid>
</UserControl>
