<UserControl x:Class="ScreenTrans.Present.HistoryPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <Grid Grid.Row="0" Margin="10,8,10,4">
      <Button x:Name="ClearAllBtn" Content="清除全部" HorizontalAlignment="Right"
              Foreground="#8A2B2B" Style="{StaticResource GhostButton}"/>
    </Grid>

    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="180"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <Border Grid.Column="0" Style="{StaticResource Card}" Margin="10,0,4,10">
        <ListBox x:Name="DateList" BorderThickness="0" Background="Transparent"
                 Margin="4" HorizontalContentAlignment="Stretch"/>
      </Border>

      <Grid Grid.Column="1">
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8,0,10,10">
          <StackPanel x:Name="EntryPanel"/>
        </ScrollViewer>
        <TextBlock x:Name="EmptyHint" Text="尚無查詢紀錄。查詢後會自動出現在這裡。"
                   Foreground="#9A6A82" FontSize="13"
                   HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
      </Grid>
    </Grid>
  </Grid>
</UserControl>
