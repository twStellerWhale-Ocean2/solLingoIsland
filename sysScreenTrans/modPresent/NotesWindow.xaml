<Window x:Class="ScreenTrans.Present.NotesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="我的筆記" Width="640" Height="480" MinWidth="520" MinHeight="340"
        ShowInTaskbar="True" WindowStartupLocation="CenterScreen" Background="#F3F3F3"
        Icon="pack://application:,,,/assets/app.ico">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="44"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <Grid Grid.Row="0" Background="#FAFAFA">
      <TextBlock Text="我的筆記" FontSize="15" FontWeight="SemiBold" Foreground="#1B1B1B"
                 VerticalAlignment="Center" Margin="16,0"/>
      <Border Height="1" Background="#E2E2E2" VerticalAlignment="Bottom"/>
    </Grid>

    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="200"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <!-- 左：資料夾 -->
      <Border Grid.Column="0" Background="#ECECEC" BorderBrush="#DCDCDC" BorderThickness="0,0,1,0">
        <DockPanel LastChildFill="True" Margin="6">
          <TextBlock DockPanel.Dock="Top" Text="資料夾" FontSize="11.5" FontWeight="SemiBold"
                     Foreground="#7A7A7A" Margin="6,4,6,6"/>
          <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="2,6,2,2">
            <Button x:Name="AddFolderBtn" Content="新增" Width="52" Height="26" FontSize="12"
                    Background="#FFFFFF" BorderBrush="#C9C9C9" BorderThickness="1" Cursor="Hand"/>
            <Button x:Name="RenameFolderBtn" Content="更名" Width="52" Height="26" Margin="4,0,0,0" FontSize="12"
                    Background="#FFFFFF" BorderBrush="#C9C9C9" BorderThickness="1" Cursor="Hand"/>
            <Button x:Name="DeleteFolderBtn" Content="刪除" Width="52" Height="26" Margin="4,0,0,0" FontSize="12"
                    Foreground="#B23B3B" Background="#FFFFFF" BorderBrush="#F0D2D2" BorderThickness="1" Cursor="Hand"/>
          </StackPanel>
          <ListBox x:Name="FolderList" BorderThickness="0" Background="Transparent"
                   HorizontalContentAlignment="Stretch"/>
        </DockPanel>
      </Border>

      <!-- 右：該夾條目 -->
      <Grid Grid.Column="1">
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="14,10">
          <StackPanel x:Name="EntryPanel"/>
        </ScrollViewer>
        <TextBlock x:Name="EmptyHint" Text="此資料夾尚無筆記。在結果或歷史按「加入我的筆記」即可收藏。"
                   Foreground="#9A9A9A" FontSize="13" TextWrapping="Wrap" MaxWidth="320"
                   TextAlignment="Center" HorizontalAlignment="Center" VerticalAlignment="Center"
                   Visibility="Collapsed"/>
      </Grid>
    </Grid>
  </Grid>
</Window>
