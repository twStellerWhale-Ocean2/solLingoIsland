<UserControl x:Class="ScreenTrans.Present.DictionaryPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ScreenTrans.Present"
        Background="Transparent">
  <!-- Dictionary 分頁（#135）：查詢結果併入主視窗。頂部文字框可手動輸入英文查詢（單字查字義、整句翻譯），
       下方共用 ResultView。整頁底色初為白、出結果後轉 70% 透明白（透出主視窗浮水印）。 -->
  <Border x:Name="PageBg" Background="White">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>

      <!-- 手動查詢輸入列 -->
      <Grid Grid.Row="0" Margin="14,12,14,8">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <TextBox x:Name="InputBox" Grid.Column="0" FontSize="16" Padding="8,6"
                 VerticalContentAlignment="Center" ToolTip="Type or paste English, then Look up (Enter)"/>
        <Button x:Name="LookupBtn" Grid.Column="1" Content="Look up" Margin="8,0,0,0" Padding="16,6"
                Cursor="Hand" Background="#F4C2D0" Foreground="#6D3A4D" BorderThickness="0" FontSize="15"/>
      </Grid>

      <!-- 結果檢視（自 ResultWindow 抽出之共用組件） -->
      <local:ResultView x:Name="Result" Grid.Row="1"/>
    </Grid>
  </Border>
</UserControl>
