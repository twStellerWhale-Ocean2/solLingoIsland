<Window x:Class="ScreenTrans.Present.ResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" Topmost="True"
        Width="560" Height="400" MinWidth="320" MinHeight="220"
        ResizeMode="NoResize" WindowStartupLocation="CenterScreen">
  <Border Background="#FFF0F5" CornerRadius="14" BorderBrush="#F4C2D0" BorderThickness="1">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="44"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <!-- 浮水印底圖（兩位女孩，極淡、不擋點擊） -->
      <Image Grid.Row="0" Grid.RowSpan="3" Source="pack://application:,,,/assets/icon.png"
             Opacity="0.10" Stretch="Uniform" IsHitTestVisible="False"
             HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20,28,20,20"/>

      <!-- 標題列：拖曳可移動視窗 -->
      <Grid x:Name="HeaderBar" Grid.Row="0" Background="Transparent" ToolTip="拖曳可移動視窗">
        <TextBlock Text="查詢結果" Foreground="#B0688A" FontSize="16"
                   VerticalAlignment="Center" Margin="18,0"/>
        <Border Height="1" Background="#F4C2D0" VerticalAlignment="Bottom"/>
      </Grid>

      <!-- 內容區：過長可捲動 -->
      <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel x:Name="BodyPanel" Margin="18,14,18,10"/>
      </ScrollViewer>

      <!-- 右上角關閉鈕 -->
      <Button x:Name="CloseBtn" Grid.Row="0"
              HorizontalAlignment="Right" VerticalAlignment="Top"
              Width="32" Height="32" Margin="0,6,8,0" Cursor="Hand" ToolTip="關閉（ESC）">
        <Button.Template>
          <ControlTemplate TargetType="Button">
            <Border x:Name="bg" CornerRadius="8" Background="Transparent">
              <TextBlock Text="✕" FontSize="16" Foreground="#B0688A"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="bg" Property="Background" Value="#F4C2D0"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Button.Template>
      </Button>

      <!-- 底部工具列（Issue #34）：加入我的筆記＋自動加入筆記；移除原歷史/我的筆記入口 -->
      <Grid Grid.Row="2">
        <Border Height="1" Background="#F4C2D0" VerticalAlignment="Top"/>
        <StackPanel Orientation="Horizontal" Margin="16,10,16,12" VerticalAlignment="Center">
          <Button x:Name="AddNoteBtn" Cursor="Hand" ToolTip="加入我的筆記">
            <Button.Template>
              <ControlTemplate TargetType="Button">
                <Border x:Name="bg" CornerRadius="8" Background="#E9F6EE" BorderBrush="#C9E6D3"
                        BorderThickness="1" Padding="12,5">
                  <TextBlock Text="＋ 加入我的筆記" FontSize="13.5" Foreground="#2F6F4A"/>
                </Border>
                <ControlTemplate.Triggers>
                  <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="bg" Property="Background" Value="#D9EFE0"/>
                  </Trigger>
                </ControlTemplate.Triggers>
              </ControlTemplate>
            </Button.Template>
          </Button>
          <CheckBox x:Name="AutoAddChk" Content="自動加入筆記" Margin="14,0,0,0"
                    VerticalAlignment="Center" Foreground="#8A5A6D" FontSize="13"/>
        </StackPanel>
      </Grid>

      <!-- 視窗右下角縮放握把（Windows 慣例，Issue #40；宣告於工具列後、z 序在上） -->
      <Thumb x:Name="ResizeGrip" Grid.Row="2"
             HorizontalAlignment="Right" VerticalAlignment="Bottom"
             Width="22" Height="22" Margin="0,0,3,3" Cursor="SizeNWSE"
             ToolTip="拖曳縮放視窗">
        <Thumb.Template>
          <ControlTemplate TargetType="Thumb">
            <Grid Background="Transparent">
              <Path Data="M 22,6 L 22,22 L 6,22 Z" Fill="#E29CB2" Stretch="Fill" Margin="6"/>
            </Grid>
          </ControlTemplate>
        </Thumb.Template>
      </Thumb>
    </Grid>
  </Border>
</Window>
