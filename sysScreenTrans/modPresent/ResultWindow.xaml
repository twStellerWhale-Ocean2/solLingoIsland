<Window x:Class="ScreenTrans.Present.ResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="查詢結果"
        Icon="pack://application:,,,/assets/app.ico"
        WindowStyle="SingleBorderWindow" ResizeMode="CanResize"
        ShowInTaskbar="True" Topmost="True"
        Background="{StaticResource PinkBg}"
        Width="560" Height="400" MinWidth="320" MinHeight="220"
        WindowStartupLocation="CenterScreen">
  <!-- Issue #59：改標準表單——標準標題列（OS 字型/標題）＋標準邊框拖拉縮放（ResizeMode=CanResize）＋
       ShowInTaskbar=True（失焦後仍有工作列按鈕可尋、不再像被隱藏）。移除原自訂 WindowStyle=None 卡片、
       自訂標題列/關閉鈕/縮放握把（改由 OS 標準 chrome 提供）。字型比照主視窗（系統預設）。 -->
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- 浮水印底圖（兩位女孩，極淡、不擋點擊） -->
    <Image Grid.Row="0" Grid.RowSpan="2" Source="pack://application:,,,/assets/icon.png"
           Opacity="0.10" Stretch="Uniform" IsHitTestVisible="False"
           HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20"/>

    <!-- 內容區：過長可捲動 -->
    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
      <StackPanel x:Name="BodyPanel" Margin="18,14,18,10"/>
    </ScrollViewer>

    <!-- 底部工具列（Issue #34）：加入我的筆記＋自動加入筆記 -->
    <Grid Grid.Row="1">
      <Border Height="1" Background="#F4C2D0" VerticalAlignment="Top"/>
      <StackPanel Orientation="Horizontal" Margin="16,10,16,12" VerticalAlignment="Center">
        <Button x:Name="AddNoteBtn" Cursor="Hand" ToolTip="加入我的筆記">
          <Button.Template>
            <ControlTemplate TargetType="Button">
              <Border x:Name="bg" CornerRadius="8" Background="#E9F6EE" BorderBrush="#C9E6D3"
                      BorderThickness="1" Padding="12,5">
                <TextBlock Text="＋ 加入我的筆記" FontSize="13.5" Foreground="#2F6F4A"/>
              </Border>
              <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                  <Setter TargetName="bg" Property="Background" Value="#D9EFE0"/>
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Button.Template>
        </Button>
        <CheckBox x:Name="AutoAddChk" Content="自動加入筆記" Margin="14,0,0,0"
                  VerticalAlignment="Center" Foreground="#8A5A6D" FontSize="13"/>
      </StackPanel>
    </Grid>
  </Grid>
</Window>
