<Window x:Class="ScreenTrans.Present.ResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Query Result"
        Icon="pack://application:,,,/assets/app.ico"
        WindowStyle="SingleBorderWindow" ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="True" Topmost="True"
        Background="{StaticResource PinkBg}"
        Width="560" Height="400" MinWidth="320" MinHeight="220"
        WindowStartupLocation="CenterScreen">
  <!-- Issue #59：改標準表單——標準標題列（OS 字型/標題）＋標準邊框拖拉縮放＋右下角縮放握把（ResizeMode=CanResizeWithGrip，#97）＋
       ShowInTaskbar=True（失焦後仍有工作列按鈕可尋、不再像被隱藏）。移除原自訂 WindowStyle=None 卡片、
       自訂標題列/關閉鈕/縮放握把（改由 OS 標準 chrome 提供）。字型比照主視窗（系統預設）。 -->
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- 浮水印底圖（兩位女孩，極淡、不擋點擊） -->
    <Image Grid.Row="0" Grid.RowSpan="3" Source="pack://application:,,,/assets/icon.png"
           Opacity="0.10" Stretch="Uniform" IsHitTestVisible="False"
           HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20"/>

    <!-- 頂部工具列（複查回饋）：往前/往後（單字查詢導航，快速返回原句）＋「加入至」資料夾（自底部上移） -->
    <Grid Grid.Row="0">
      <Border Height="1" Background="#F4C2D0" VerticalAlignment="Bottom"/>
      <StackPanel Orientation="Horizontal" Margin="14,8,16,8" VerticalAlignment="Center">
        <Button x:Name="BackBtn" Content="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                Width="30" Height="26" Cursor="Hand" ToolTip="Back (return to previous)"
                Background="#66FFFFFF" BorderBrush="#E4B7C6" BorderThickness="1" Foreground="#6D3A4D"/>
        <Button x:Name="ForwardBtn" Content="&#xE72A;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                Width="30" Height="26" Margin="6,0,0,0" Cursor="Hand" ToolTip="Forward"
                Background="#66FFFFFF" BorderBrush="#E4B7C6" BorderThickness="1" Foreground="#6D3A4D"/>
        <TextBlock Text="Add to" VerticalAlignment="Center" Foreground="#8A5A6D" FontSize="12.5" Margin="16,0,6,0"/>
        <ComboBox x:Name="FolderCombo" MinWidth="118" MaxWidth="200" FontSize="12.5" VerticalAlignment="Center"/>
      </StackPanel>
    </Grid>

    <!-- 內容區：過長可捲動 -->
    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
      <StackPanel x:Name="BodyPanel" Margin="18,14,18,10"/>
    </ScrollViewer>

    <!-- 底部工具列（Issue #34）：加入我的筆記＋自動加入筆記；下方為底色（Issue #55；#複查：資料夾下拉上移頂部） -->
    <Grid Grid.Row="2">
      <Border Height="1" Background="#F4C2D0" VerticalAlignment="Top"/>
      <StackPanel Margin="16,10,16,12">
        <StackPanel Orientation="Horizontal">
          <Button x:Name="AddNoteBtn" Cursor="Hand" ToolTip="Add to My Notes">
            <Button.Template>
              <ControlTemplate TargetType="Button">
                <Border x:Name="bg" CornerRadius="8" Background="#E9F6EE" BorderBrush="#C9E6D3"
                        BorderThickness="1" Padding="12,5">
                  <TextBlock Text="＋ Add to My Notes" FontSize="13.5" Foreground="#2F6F4A"/>
                </Border>
                <ControlTemplate.Triggers>
                  <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="bg" Property="Background" Value="#D9EFE0"/>
                  </Trigger>
                </ControlTemplate.Triggers>
              </ControlTemplate>
            </Button.Template>
          </Button>
          <CheckBox x:Name="AutoAddChk" Content="Auto-add to Notes" Margin="14,0,0,0"
                    VerticalAlignment="Center" Foreground="#8A5A6D" FontSize="13"/>
        </StackPanel>
        <!-- #55：底色色塊列（加入至資料夾下拉已於 #複查 上移頂部工具列） -->
        <!-- #109 十色（11 塊）：DockPanel 使 WrapPanel 取得「實際剩餘寬」而非無限寬——窗窄時換行全可視可點，不裁切 -->
        <DockPanel Margin="0,8,0,0">
          <TextBlock DockPanel.Dock="Left" Text="Color" VerticalAlignment="Center" Foreground="#8A5A6D" FontSize="12.5" Margin="0,0,6,0"/>
          <WrapPanel x:Name="SwatchRow" Orientation="Horizontal" VerticalAlignment="Center"/>
        </DockPanel>
      </StackPanel>
    </Grid>
  </Grid>
</Window>
