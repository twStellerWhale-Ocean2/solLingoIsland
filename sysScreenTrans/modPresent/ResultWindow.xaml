<Window x:Class="ScreenTrans.Present.ResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" Topmost="True" Width="440" SizeToContent="Height"
        ResizeMode="NoResize" WindowStartupLocation="CenterScreen">
  <Border Background="#202226" CornerRadius="10" BorderBrush="#3C4043" BorderThickness="1">
    <StackPanel>
      <Grid Height="34">
        <TextBlock Text="查詢結果" Foreground="#9AA0A6" FontSize="11"
                   VerticalAlignment="Center" Margin="12,0"/>
        <TextBlock Text="✕ ESC" Foreground="#9AA0A6" FontSize="11"
                   HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,12,0"/>
        <Border Height="1" Background="#2E3238" VerticalAlignment="Bottom"/>
      </Grid>
      <StackPanel x:Name="BodyPanel" Margin="12,9,12,11"/>
    </StackPanel>
  </Border>
</Window>
